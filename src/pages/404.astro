---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | 505local.com"
  description="The page you are looking for does not exist. Return to the home page of 505local.com."
>
  <main class="min-h-screen flex items-center justify-center bg-slate-50">
    <div class="text-center px-8">
      <div class="text-6xl font-display font-semibold text-accent-500 mb-6">404</div>
      <h1 class="text-4xl font-semibold tracking-tighter mb-4">Page Not Found</h1>
      <p class="text-slate-500 max-w-md mx-auto mb-8">
        The page you are looking for does not exist. Return to the home page to explore domain acquisition opportunities.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-x-2 px-8 py-3 bg-accent-500 hover:bg-accent-600 text-white rounded-2xl font-semibold transition-colors text-sm tracking-wide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
        </svg>
        Return Home
      </a>
      <meta name="robots" content="noindex" />
    </div>
  </main>
</BaseLayout>
