---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import WhySection from '../components/WhySection.astro';
import OpportunitySection from '../components/OpportunitySection.astro';
import MarketSection from '../components/MarketSection.astro';
import ValueSection from '../components/ValueSection.astro';
import AcquireSection from '../components/AcquireSection.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
import Modals from '../components/Modals.astro';
---

<BaseLayout
  title="505Local.com | Premium Domain for Sale • New Mexico 505 Local Authority"
  description="505Local.com — The premium, brandable .com domain for hyperlocal New Mexico and the 505 area code. Perfect for local platforms, directories, events, or instantly elevating any Albuquerque or Santa Fe-area business. Now available."
>
  <Nav />
  <Hero />
  <TrustBar />
  <WhySection />
  <OpportunitySection />
  <MarketSection />
  <ValueSection />
  <AcquireSection />
  <CTASection />
  <Footer />
  <Modals />

  <script>
    // Modal helper functions
    function showModal(id: string) {
      const modal = document.getElementById(id);
      if (!modal) return;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      setTimeout(() => {
        const firstInput = modal.querySelector('input, select, textarea') as HTMLElement;
        firstInput?.focus();
      }, 300);
    }

    function hideModal(id: string) {
      const modal = document.getElementById(id);
      if (!modal) return;
      modal.classList.remove('flex');
      modal.classList.add('hidden');
    }

    // Navbar scroll effect
    function initNavbar() {
      const nav = document.getElementById('nav');
      if (!nav) return;

      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          nav.style.boxShadow = '0 1px 0 0 rgb(15 23 42 / 0.06)';
          nav.style.backgroundColor = 'rgba(255,255,255,0.95)';
          nav.style.backdropFilter = 'blur(12px)';
        } else {
          nav.style.boxShadow = '';
          nav.style.backgroundColor = '';
          nav.style.backdropFilter = '';
        }
      });
    }

    // Mobile menu toggle
    function toggleMobileMenu() {
      const existing = document.querySelector('[data-mobile-nav]');
      if (existing) {
        existing.remove();
        return;
      }

      const mobileNav = document.createElement('div');
      mobileNav.setAttribute('data-mobile-nav', '');
      mobileNav.className = 'fixed inset-0 bg-black/60 z-[200] md:hidden';
      mobileNav.innerHTML = `
        <div class="bg-white w-72 h-full p-8 shadow-2xl">
          <div class="flex justify-between items-center mb-10">
            <div class="flex items-center gap-x-2.5">
              <div class="w-9 h-9 bg-slate-900 rounded-2xl flex items-center justify-center">
                <span class="text-white font-display text-xl font-semibold tracking-tighter">505</span>
              </div>
              <span class="font-display text-2xl font-semibold tracking-tighter">Local</span>
            </div>
            <button class="text-3xl text-slate-400 hover:text-slate-600" id="mobileClose">&times;</button>
          </div>

          <div class="flex flex-col gap-y-1 text-lg font-medium">
            <a href="#why" class="py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">Why This Domain</a>
            <a href="#opportunity" class="py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">The Opportunity</a>
            <a href="#value" class="py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">Market Value</a>
            <a href="#acquire" class="py-3 px-1 text-slate-700 hover:text-slate-900 border-b border-slate-100">How to Acquire</a>
          </div>

          <div class="mt-auto pt-8">
            <button id="mobileInquire" class="w-full py-4 bg-slate-900 text-white font-semibold rounded-2xl text-sm">
              Make an Offer
            </button>
          </div>
        </div>
      `;

      document.body.appendChild(mobileNav);

      (mobileNav.querySelector('#mobileClose') as HTMLElement).onclick = () => mobileNav.remove();
      mobileNav.onclick = (e) => { if (e.target === mobileNav) mobileNav.remove(); };

      mobileNav.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileNav.remove();
          setTimeout(() => {
            const target = document.querySelector(link.getAttribute('href')!);
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 80);
        });
      });

      (mobileNav.querySelector('#mobileInquire') as HTMLElement).onclick = () => {
        mobileNav.remove();
        showModal('offerModal');
      };
    }

    // Offer form submission
    function handleOfferSubmit(e: Event) {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      if (!submitBtn) return;

      const originalText = submitBtn.innerHTML;

      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <span class="flex items-center justify-center gap-x-2">
          <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span>Submitting...</span>
        </span>
      `;

      setTimeout(() => {
        hideModal('offerModal');
        form.reset();
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
        showModal('successModal');
      }, 1250);
    }

    // Smooth scroll for anchor links
    function initSmoothScroll() {
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', function (this: HTMLAnchorElement, e: Event) {
          const target = document.querySelector(this.getAttribute('href')!);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    }

    // Keyboard controls
    function initKeyboardControls() {
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          const offerModal = document.getElementById('offerModal');
          const successModal = document.getElementById('successModal');
          if (successModal && !successModal.classList.contains('hidden')) {
            hideModal('successModal');
          } else if (offerModal && !offerModal.classList.contains('hidden')) {
            hideModal('offerModal');
          }
        }
      });
    }

    // Initialize everything
    function init() {
      initNavbar();
      initSmoothScroll();
      initKeyboardControls();

      // Mobile menu
      document.getElementById('mobileToggle')?.addEventListener('click', toggleMobileMenu);

      // CTA buttons that open offer modal
      const ctaButtons = ['navOfferBtn', 'navInquireBtn', 'heroCta', 'finalCta', 'footerInquire'];
      ctaButtons.forEach((id) => {
        document.getElementById(id)?.addEventListener('click', () => showModal('offerModal'));
      });

      // Modal close buttons
      document.getElementById('modalClose')?.addEventListener('click', () => hideModal('offerModal'));
      document.getElementById('offerModal')?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).id === 'offerModal') hideModal('offerModal');
      });
      document.getElementById('successClose')?.addEventListener('click', () => hideModal('successModal'));
      document.getElementById('successModal')?.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).id === 'successModal') hideModal('successModal');
      });

      // Form submission
      document.getElementById('offerForm')?.addEventListener('submit', handleOfferSubmit);

      // Logo click scrolls to top
      const logo = document.querySelector('a[href="/"]');
      if (logo) {
        logo.addEventListener('click', (e) => {
          if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
            e.preventDefault();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        });
      }
    }

    document.addEventListener('DOMContentLoaded', init);
  </script>
</BaseLayout>
